#------------------------------------------------------------------------------
# Application
#------------------------------------------------------------------------------
APP_NAME=ShipNest
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Dhaka
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=12

#------------------------------------------------------------------------------
# Logging
#------------------------------------------------------------------------------
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

#------------------------------------------------------------------------------
# Database (MySQL 8)
#------------------------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=shipnest
DB_USERNAME=root
DB_PASSWORD=

#------------------------------------------------------------------------------
# Redis (cache + queue + sessions)
#------------------------------------------------------------------------------
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

CACHE_STORE=database
CACHE_PREFIX=shipnest_

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

QUEUE_CONNECTION=database

#------------------------------------------------------------------------------
# Broadcasting (Pusher + Laravel Echo)
#------------------------------------------------------------------------------
BROADCAST_CONNECTION=log

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https

VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"

#------------------------------------------------------------------------------
# Mail
#------------------------------------------------------------------------------
MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="support@shipnest.com"
MAIL_FROM_NAME="${APP_NAME}"

#------------------------------------------------------------------------------
# Filesystem (S3-ready)
#------------------------------------------------------------------------------
FILESYSTEM_DISK=local

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

#------------------------------------------------------------------------------
# Search (Laravel Scout + MeiliSearch)
#------------------------------------------------------------------------------
SCOUT_DRIVER=collection
MEILISEARCH_HOST=http://127.0.0.1:7700
MEILISEARCH_KEY=

#------------------------------------------------------------------------------
# ShipNest Platform
#------------------------------------------------------------------------------
SHIPNEST_NAME="${APP_NAME}"
SHIPNEST_CURRENCY=BDT
SHIPNEST_CURRENCY_SYMBOL=৳
SHIPNEST_FREE_SHIPPING_THRESHOLD=500
SHIPNEST_COMMISSION_RATE=10
SHIPNEST_SUPPORT_EMAIL=support@shipnest.com
SHIPNEST_SUPPORT_PHONE="+880 1700-000000"
SHIPNEST_ADMIN_NOTIFICATION_EMAIL=admin@shipnest.com

#------------------------------------------------------------------------------
# SMS / OTP (mock | twilio)
#------------------------------------------------------------------------------
SMS_DRIVER=mock
TWILIO_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

#------------------------------------------------------------------------------
# Social Login (Laravel Socialite)
#------------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URI="${APP_URL}/auth/facebook/callback"

#------------------------------------------------------------------------------
# SSLCommerz
#------------------------------------------------------------------------------
SSLCOMMERZ_STORE_ID=
SSLCOMMERZ_STORE_PASSWORD=
SSLCOMMERZ_API_URL=https://sandbox.sslcommerz.com
SSLCOMMERZ_SANDBOX=true

#------------------------------------------------------------------------------
# bKash
#------------------------------------------------------------------------------
BKASH_APP_KEY=
BKASH_APP_SECRET=
BKASH_USERNAME=
BKASH_PASSWORD=
BKASH_BASE_URL=https://tokenized.sandbox.bka.sh/v1.2.0-beta
BKASH_SANDBOX=true

#------------------------------------------------------------------------------
# Nagad
#------------------------------------------------------------------------------
NAGAD_MERCHANT_ID=
NAGAD_MERCHANT_NUMBER=
NAGAD_PUBLIC_KEY=
NAGAD_PRIVATE_KEY=
NAGAD_CHALLENGE=
NAGAD_BASE_URL=https://api.mynagad.com/api/dfs
NAGAD_SANDBOX=true

#------------------------------------------------------------------------------
# Stripe (International cards)
# Get keys: https://dashboard.stripe.com/apikeys
# Webhook: https://dashboard.stripe.com/webhooks → endpoint: /payment/webhook/stripe
#------------------------------------------------------------------------------
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=usd
PAYMENT_STRIPE_ENABLED=false
PAYMENT_COD_ENABLED=true
PAYMENT_SSLCOMMERZ_ENABLED=true
PAYMENT_BKASH_ENABLED=true
PAYMENT_NAGAD_ENABLED=true

#------------------------------------------------------------------------------
# Vite
#------------------------------------------------------------------------------
VITE_APP_NAME="${APP_NAME}"
